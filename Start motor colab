import os
import sys
import shutil
import urllib.request
import zipfile
import base64

print("⏳ Iniciando a reconstrução do ambiente GER de forma blindada (Anti-Truncamento)...")

# 1. Limpeza preventiva total de pastas antigas
for p in ["/content/GER", "/content/GER.zip", "/content/GER-main"]:
    if os.path.exists(p):
        if os.path.isdir(p):
            shutil.rmtree(p)
        else:
            os.remove(p)

# 2. Link Criptografado em Base64 (Impede que o filtro do Colab intercepte e corte o texto)
# O texto abaixo equivale a: https://github.com/eduardobatistadefreitas-art/GER/archive/refs/heads/main.zip
link_criptografado = "aHR0cHM6Ly9naXRodWIuY29tL2VkdWFyZG9iYXRpc3RhZGVmcmVpdGFzLWFydC9HRVIvYXJjaGl2ZS9yZWZzL2hlYWRzL21haW4uemlw"
url_alvo = base64.b64decode(link_criptografado).decode('utf-8')

print(f"🔗 URL Reconstruída na Memória: {url_alvo}")
arquivo_destino = "/content/GER.zip"

try:
    print("📥 Baixando pacote de dados diretamente do repositório...")
    # Configura um identificador de navegador para o GitHub liberar o download
    requisicao = urllib.request.Request(url_alvo, headers={'User-Agent': 'Mozilla/5.0'})
    
    with urllib.request.urlopen(requisicao) as resposta, open(arquivo_destino, 'wb') as arquivo_out:
        shutil.copyfileobj(resposta, arquivo_out)
        
    print("📦 Extraindo estrutura de diretórios...")
    with zipfile.ZipFile(arquivo_destino, 'r') as zip_ref:
        zip_ref.extractall("/content")
        
    # Organiza e padroniza o nome da pasta principal
    if os.path.exists("/content/GER-main"):
        os.rename("/content/GER-main", "/content/GER")
        print("✅ Download e extração concluídos com sucesso!")
        
    if os.path.exists(arquivo_destino):
        os.remove(arquivo_destino)

except Exception as e:
    print(f"❌ Erro na transferência de dados: {e}")

# 3. Tratamento dos arquivos .py (Limpando sintaxe inválida e rotas)
caminho_base = "/content/GER"
if os.path.exists(caminho_base):
    print("🛠️ Tratando os arquivos .py (Limpando sintaxe e rotas de importação)...")
    for raiz, _, arquivos in os.walk(caminho_base):
        for arquivo in arquivos:
            if arquivo.endswith(".py"):
                caminho_arquivo = os.path.join(raiz, arquivo)
                
                with open(caminho_arquivo, "r", encoding="utf-8") as f:
                    linhas = f.readlines()
                
                # Deleta comandos magics como %%writefile
                linhas_filtradas = [l for l in linhas if "%%writefile" not in l]
                texto_limpo = "".join(linhas_filtradas)
                
                # Remove o prefixo GER_CORE. para corrigir as importações internas
                texto_corrigido = texto_limpo.replace("GER_CORE.", "")
                
                with open(caminho_arquivo, "w", encoding="utf-8") as f:
                    f.write(texto_corrigido)

